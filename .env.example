
# --- Application ---
APP_NAME=Mobilismart
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

# --- Backend (Laravel) ---
BACKEND_PORT=8000
APP_KEY=base64:YOUR_APP_KEY_HERE

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE
NEXT_PUBLIC_APP_NAME=Mobilismart
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# --- Database (PostgreSQL + PostGIS) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mobilismart
DB_USERNAME=mobilismart
DB_PASSWORD=secret_password_change_me

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- AI Service (FastAPI) ---
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_PORT=8001

# --- Cache & Queue ---
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost

# --- Mail (for notifications) ---
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@mobilismart.app
MAIL_FROM_NAME="${APP_NAME}"

# --- External APIs ---
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE
NAVITIA_API_KEY=your_navitia_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_key
PUSHER_APP_SECRET=your_pusher_secret
PUSHER_APP_CLUSTER=eu

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
